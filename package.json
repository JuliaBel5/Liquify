{
  "name": "liquify",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev": "pnpm --filter @liquify/web dev",
    "start": "pnpm --filter @liquify/web start"
  },
  "devDependencies": {
    "next": "15.5.18",
    "typescript": "5.7.3"
  }
}
